{
  "name": "muxlyve",
  "version": "0.3.4",
  "description": "App propia de retransmisión (restreaming) a Twitch, Kick, TikTok Live y YouTube — sin marca de agua.",
  "author": "BLACKRAKEN SOLUTIONS <nabaol.dev@gmail.com>",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "start": "node --env-file-if-exists=.env src/index.js",
    "dev": "node --watch --env-file-if-exists=.env src/index.js",
    "validate": "node scripts/validate.mjs",
    "validate:panel": "node scripts/validate-panel-script.mjs",
    "test:unit": "node --test \"test/**/*.test.mjs\"",
    "test": "npm run test:unit && bash scripts/smoke-test.sh",
    "electron": "node -r dotenv/config ./node_modules/.bin/electron .",
    "predist": "node scripts/generate-installer-bmps.mjs && node -r dotenv/config scripts/generate-oauth-credentials.mjs",
    "dist": "node -r dotenv/config node_modules/electron-builder/cli.js --win",
    "predist:publish": "node scripts/generate-installer-bmps.mjs && node -r dotenv/config scripts/generate-oauth-credentials.mjs && node -r dotenv/config scripts/create-draft-release.mjs",
    "dist:publish": "node -r dotenv/config node_modules/electron-builder/cli.js --publish always",
    "postdist:publish": "node -r dotenv/config scripts/cleanup-orphan-releases.mjs",
    "dist:mac": "node -r dotenv/config scripts/generate-oauth-credentials.mjs && node scripts/download-ffmpeg-mac.mjs && bash scripts/make-icns.sh && electron-builder --mac"
  },
  "keywords": [
    "rtmp",
    "restream",
    "streaming",
    "ffmpeg",
    "obs",
    "Streamlabs",
    "XSplit",
    "Twitch",
    "Kick",
    "YouTube",
    "TikTok Live"
  ],
  "license": "MIT",
  "build": {
    "appId": "com.naba.muxlyve",
    "productName": "Muxlyve",
    "afterPack": "scripts/afterpack-adhoc-sign.cjs",
    "directories": {
      "output": "dist-app",
      "buildResources": "build"
    },
    "files": [
      "**/*",
      "!config/destinations.json",
      "!config/destinations.json.bak",
      "!.env",
      "!.env.example",
      "!dist-app/**",
      "!docs/**",
      "!scripts/**",
      "!**/*.bak"
    ],
    "asarUnpack": [
      "node_modules/ffmpeg-static/**"
    ],
    "protocols": [
      {
        "name": "Muxlyve OAuth",
        "schemes": [
          "muxlyve"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon-muxlyve.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "menuCategory": "Muxlyve",
      "shortcutName": "Muxlyve",
      "installerIcon": "build/icon-muxlyve.ico",
      "uninstallerIcon": "build/unicon-muxlyve.ico",
      "installerHeaderIcon": "build/icon-muxlyve.ico",
      "installerSidebar": "build/installer-sidebar.bmp",
      "uninstallerSidebar": "build/installer-sidebar.bmp",
      "uninstallDisplayName": "Muxlyve",
      "runAfterFinish": true,
      "language": "1034",
      "include": "build/installer.nsh"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.icns",
      "identity": null,
      "extraResources": [
        {
          "from": "build/mac/ffmpeg",
          "to": "ffmpeg"
        },
        {
          "from": "build/mac/libs",
          "to": "libs"
        }
      ],
      "category": "public.app-category.video"
    },
    "dmg": {
      "title": "Muxlyve"
    },
    "publish": {
      "provider": "github",
      "owner": "NABA-OL",
      "repo": "Muxlyve",
      "releaseType": "release"
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "ffmpeg-static": "^5.3.0",
    "node-media-server": "^2.6.0"
  },
  "devDependencies": {
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3"
  }
}
