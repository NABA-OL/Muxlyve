{
  "name": "multi-stream",
  "version": "0.1.0",
  "description": "App propia de retransmisión (restreaming) a Twitch, Kick, TikTok Live y YouTube — sin marca de agua.",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "start": "node --env-file-if-exists=.env src/index.js",
    "dev": "node --watch --env-file-if-exists=.env src/index.js",
    "validate": "node scripts/validate.mjs",
    "test": "bash scripts/smoke-test.sh",
    "electron": "electron .",
    "dist": "electron-builder --win"
  },
  "keywords": [
    "rtmp",
    "restream",
    "streaming",
    "ffmpeg",
    "obs"
  ],
  "license": "MIT",
  "build": {
    "appId": "com.naba.multistream",
    "productName": "Multi_Stream",
    "directories": {
      "output": "dist-app",
      "buildResources": "build"
    },
    "files": [
      "**/*",
      "!config/destinations.json",
      "!config/destinations.json.bak",
      "!.env",
      "!.env.example",
      "!dist-app/**",
      "!docs/**",
      "!scripts/**",
      "!**/*.bak"
    ],
    "asarUnpack": [
      "node_modules/ffmpeg-static/**"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "ffmpeg-static": "^5.3.0",
    "node-media-server": "^2.6.0"
  },
  "devDependencies": {
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3"
  }
}
