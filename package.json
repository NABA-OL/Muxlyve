{
  "name": "muxlyve",
  "version": "0.2.1",
  "description": "App propia de retransmisión (restreaming) a Twitch, Kick, TikTok Live y YouTube — sin marca de agua.",
  "author": "NABA-OL <nabaol.dev@gmail.com>",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "start": "node --env-file-if-exists=.env src/index.js",
    "dev": "node --watch --env-file-if-exists=.env src/index.js",
    "validate": "node scripts/validate.mjs",
    "test": "bash scripts/smoke-test.sh",
    "electron": "node -r dotenv/config ./node_modules/.bin/electron .",
    "dist": "electron-builder --win",
    "predist:publish": "node -r dotenv/config scripts/create-draft-release.mjs",
    "dist:publish": "node -r dotenv/config node_modules/electron-builder/cli.js --publish always",
    "dist:mac": "node scripts/download-ffmpeg-mac.mjs && bash scripts/make-icns.sh && electron-builder --mac"
  },
  "keywords": [
    "rtmp",
    "restream",
    "streaming",
    "ffmpeg",
    "obs"
  ],
  "license": "MIT",
  "build": {
    "appId": "com.naba.muxlyve",
    "productName": "Muxlyve",
    "directories": {
      "output": "dist-app",
      "buildResources": "build"
    },
    "files": [
      "**/*",
      "!config/destinations.json",
      "!config/destinations.json.bak",
      "!.env",
      "!.env.example",
      "!dist-app/**",
      "!docs/**",
      "!scripts/**",
      "!**/*.bak"
    ],
    "asarUnpack": [
      "node_modules/ffmpeg-static/**"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon-muxlyve.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "menuCategory": "Muxlyve",
      "shortcutName": "Muxlyve",
      "installerIcon": "build/icon-muxlyve.ico",
      "uninstallerIcon": "build/icon-muxlyve.ico",
      "installerHeaderIcon": "build/icon-muxlyve.ico",
      "uninstallDisplayName": "Muxlyve",
      "runAfterFinish": true,
      "language": "1034",
      "include": "build/installer.nsh"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.icns",
      "extraResources": [
        {
          "from": "build/mac/ffmpeg",
          "to": "ffmpeg"
        },
        {
          "from": "build/mac/libs",
          "to": "libs"
        }
      ],
      "category": "public.app-category.video"
    },
    "dmg": {
      "title": "Muxlyve"
    },
    "publish": {
      "provider": "github",
      "owner": "NABA-OL",
      "repo": "Muxlyve"
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "ffmpeg-static": "^5.3.0",
    "node-media-server": "^2.6.0"
  },
  "devDependencies": {
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3"
  }
}
