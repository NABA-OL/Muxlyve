# Puerto donde OBS enviará la señal (RTMP de ingest local)
RTMP_PORT=19350
# Puerto del servidor HTTP interno de node-media-server
HTTP_PORT=19000
# Puerto del panel web de gestión (solo localhost por defecto)
PANEL_PORT=19080

# true = el panel/API también escucha en tu red local (0.0.0.0), no solo localhost.
# Necesario para: overlay de chat en OBS desde otra máquina, plugin de Stream Deck
# controlando Muxlyve desde otra máquina. Con esto en true, las rutas sensibles (claves
# RTMP, prender/apagar destinos, mandar/fijar chat como vos) exigen el token de abajo
# desde fuera de este equipo — el overlay de chat (/chat-overlay) sigue sin token porque
# OBS no puede mandar headers. Dejalo en false salvo que lo necesites.
ALLOW_LAN_PANEL=false

# Token compartido para clientes remotos (ej. plugin de Stream Deck) cuando
# ALLOW_LAN_PANEL=true. Vacío = se genera solo al primer arranque y se guarda en
# config/panel-token.json (o MS_CONFIG_DIR) — mostrado en el panel (Información de
# conexión) para copiarlo. Definilo acá solo si querés fijarlo vos a mano.
PANEL_TOKEN=

# Clave que OBS usará al publicar. En OBS:
#   Servidor: rtmp://localhost:19350/live
#   Clave de retransmisión: el valor de STREAM_KEY
STREAM_KEY=mistream

# Clave maestra para cifrar las claves de stream en reposo (AES-256-GCM).
# Genera una fuerte: openssl rand -base64 32
# Si se deja vacía, las claves se guardan en texto plano (no recomendado).
MASTER_KEY=

# ── OAuth de plataformas (Grupo B) ─────────────────────────────────────────────
# Registra tu app en https://dev.twitch.tv/console/apps
# Redirect URI a configurar: http://localhost:19080/oauth/twitch
# PKCE activo. Si tu app en Twitch es tipo "Confidential" (tiene Client Secret
# generado), Twitch EXIGE ese secret en el intercambio de token aunque uses PKCE —
# rellena TWITCH_CLIENT_SECRET. Si es "Public", déjalo vacío.
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# Registra tu app en https://console.cloud.google.com → APIs & Services → OAuth 2.0
# Tipo: Desktop app (no tiene campo de redirect URI — usa http://localhost:19080/oauth/youtube
# automáticamente; Google NO acepta esquemas propios como muxlyve:// para este tipo de cliente).
# Scopes: youtube.readonly
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Registra tu app en https://dev.kick.com (Kick for Developers)
# Redirect URI a configurar: http://localhost:19080/oauth/kick
# Cliente confidencial — Kick exige client_secret en el intercambio de token aunque
# el flujo use PKCE. Scopes: user:read channel:read
KICK_CLIENT_ID=
KICK_CLIENT_SECRET=

