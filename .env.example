# Puerto donde OBS enviará la señal (RTMP de ingest local)
RTMP_PORT=1935
# Puerto del servidor HTTP interno de node-media-server
HTTP_PORT=8000
# Puerto del panel web de gestión (solo localhost)
PANEL_PORT=8080

# Clave que OBS usará al publicar. En OBS:
#   Servidor: rtmp://localhost:1935/live
#   Clave de retransmisión: el valor de STREAM_KEY
STREAM_KEY=mistream
